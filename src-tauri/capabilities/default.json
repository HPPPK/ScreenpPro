{
    "$schema":  "../gen/schemas/desktop-schema.json",
    "identifier":  "default",
    "description":  "ScreenPro desktop capabilities",
    "windows":  [
                    "main",
                    "saver-*"
                ],
    "permissions":  [
                        "core:default",
                        "dialog:default",
                        "global-shortcut:allow-register",
