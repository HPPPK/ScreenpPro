{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "ScreenPro",
    "version":  "0.1.0",
    "identifier":  "com.screenpro.desktop",
    "build":  {
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:1420",
                  "beforeDevCommand":  "bun run dev",
                  "beforeBuildCommand":  "bun run build"
              },
    "app":  {
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "ScreenPro",
                                    "width":  1440,
                                    "height":  920,
                                    "minWidth":  1120,
                                    "minHeight":  720,
                                    "resizable":  true,
                                    "center":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               },
    "plugins":  {
                    "updater":  {
                                    "pubkey":  "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEQjYzNUYyQTM0NDM1RTAKUldUZ05VU2o4alcyL2FYaXRXbEMrcUVRK3pOY0gxUmMrY3Z3dlFrTk5DMmFhSXQ1RXFRMG41TkkK",
                                    "endpoints":  [
                                                      "https://github.com/HPPPK/ScreenpPro/releases/latest/download/latest.json"
                                                  ]
                                }
                }
}